{
  "name": "@velocity-bpa/n8n-nodes-iotex",
  "version": "1.0.2",
  "description": "n8n community node for IoTeX blockchain API integration",
  "license": "bsl-catalog",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "files": [
    "dist/**/*"
  ],
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "n8n-node",
    "iotex",
    "blockchain",
    "api"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/IoTeXApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/IoTeX/IoTeX.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "n8n-workflow": "*"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}